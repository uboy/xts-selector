# Copy this file to .env and fill in real paths.
# Never commit .env — it contains local absolute paths.
#
# Source before running validation:
#   source .env && make validate-golden

# Path to the ace_engine checkout (foundation/arkui/ace_engine)
# ARKUI_ACE_ENGINE_ROOT=/path/to/openharmony/foundation/arkui/ace_engine

# Path to the interface/sdk-js checkout
# INTERFACE_SDK_JS_ROOT=/path/to/openharmony/interface/sdk-js

# Path to the XTS/ACTS test checkout (test/xts/acts)
# XTS_ACTS_ROOT=/path/to/openharmony/test/xts/acts

# Cache directory for intermediate selector artefacts (default: .cache/arkui-xts-selector)
# ARKUI_XTS_CACHE_DIR=.cache/arkui-xts-selector
