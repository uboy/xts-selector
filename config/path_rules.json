    },
    "ohosprompt": {
      "modules": ["@ohos.prompt"],
      "symbols": ["prompt", "Prompt"]
    },
    "scrollable": {
      "symbols": ["Scroll", "List", "Grid", "WaterFlow", "Scroller",
                   "ScrollModifier", "ListModifier", "GridModifier", "WaterFlowModifier"],
      "project_hints": ["scroll", "list", "grid", "waterflow"]
