      "expires_at": "2027-12-31",
      "owner": "arkui-bridge-ets",
      "ticket": "OHOS-BRIDGE-001",
      "rationale": "Bridge files affect JS-ETS interop and require both state management and component tests"
    },
    {
      "path_regex": "frameworks/core/pipeline_ng/.*\\.cpp$",
      "must_run_targets": ["ace_ets_component_seven/ace_ets_component_common_seven_attrs_opacity"],
      "expires_at": "2027-12-31",
      "owner": "arkui-render",
      "ticket": "OHOS-RENDER-001",
      "rationale": "Pipeline changes affect rendering behavior, test opacity and visual attributes"
    },
    {
      "path_regex": "frameworks/core/components_ng/render/canvas.*\\.cpp$",
