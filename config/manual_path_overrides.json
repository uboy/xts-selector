      "expires_at": "2027-12-31",
      "owner": "arkui-render",
      "ticket": "OHOS-CANVAS-001",
      "rationale": "Canvas rendering changes require attribute testing"
    },
    {
      "path_regex": "frameworks/bridge/declarative_frontend/js_.*\\.cpp$",
      "must_run_targets": ["ace_ets_module_noui/ace_ets_module_StateMangagement"],
      "expires_at": "2027-12-31",
      "owner": "arkui-bridge-js",
      "ticket": "OHOS-JS-BRIDGE-001",
      "rationale": "JS bridge files affect state management integration"
    },
    {
