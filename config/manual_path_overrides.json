      "expires_at": "2027-12-31",
      "owner": "arkui-animation",
      "ticket": "OHOS-ANIM-001",
      "rationale": "Animation changes affect state management and transitions"
    },
    {
      "path_regex": "frameworks/core/accessibility/.*\\.cpp$",
